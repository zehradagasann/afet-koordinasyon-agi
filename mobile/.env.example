# RESQ Mobile - Environment Variables
# This file is a template. Copy to .env and fill in your values.

# API Configuration
# Backend kok URL'si (no /api suffix). Servisler kendi prefix'lerini ekler.
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_TIMEOUT=10000

# App Configuration
EXPO_PUBLIC_APP_NAME=RESQ
EXPO_PUBLIC_APP_VERSION=0.1.0

# Firebase (Optional - for future push notifications)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_APP_ID=your-app-id
# FIREBASE_API_KEY=your-api-key
# FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Google Maps API (Optional - for advanced map features)
# EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Debug Mode (Set to 'true' for development)
DEBUG=false
